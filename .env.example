# ===== ENVIRONMENT & SECURITY =====
NODE_ENV=development
TRUST_PROXY=false # set to true when behind a trusted reverse proxy (e.g. Heroku, Render, Railway)
ALLOWED_ORIGINS=http://localhost:3000
RENDER_EXTERNAL_URL= # optional: add Render external URL here when deployed on Render

# ===== SERVER =====
PORT=3000

# ===== MONGODB =====
MONGO_URI=mongodb://localhost:27017/teerhub

# ===== JWT AUTHENTICATION =====
JWT_SECRET=your-super-secret-jwt-key-change-this-must-be-at-least-32-characters
JWT_EXPIRES_IN=7d

# ===== SESSION MANAGEMENT =====
# SESSION_SECRET: REQUIRED in production. Set a strong, unique secret (>=32 chars).
SESSION_SECRET=your-super-secret-session-key-change-this-must-be-at-least-32-characters

# MESSAGE_ENC_KEY: optional key for message encryption/decryption
MESSAGE_ENC_KEY=your-super-secret-message-encryption-key
SESSION_SAME_SITE=lax

# ===== SECURITY HEADERS =====
# HSTS max age in seconds (default: 31536000 = 1 year)
HSTS_MAX_AGE=31536000

# ===== LOGGING =====
LOG_LEVEL=info

# ===== RATE LIMITING =====
# General rate limit: max requests per 15 minutes
RATE_LIMIT_GENERAL=100

# Auth rate limit: max login attempts per 15 minutes
RATE_LIMIT_AUTH=5

# ===== REQUEST SIZE LIMITS =====
# Maximum JSON payload size
MAX_JSON_SIZE=10kb

# Maximum URL-encoded payload size
MAX_URL_SIZE=10kb
